.minor-notice-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  min-height: 52rpx;
  padding: 8rpx 20rpx;
  border-radius: var(--radius-sm);
  background: var(--color-bg-elevated);
  border: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.minor-notice-bar__badge {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 32rpx;
  height: 32rpx;
  border-radius: 50%;
  background: var(--color-minor-notice-badge-bg);
  box-shadow: 0 2rpx 8rpx var(--color-minor-notice-badge-shadow);
}

.minor-notice-bar__icon {
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1;
  color: var(--color-minor-notice-badge-fg);
}

.minor-notice-bar__line {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
  line-height: 1.35;
  color: var(--color-text-secondary);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.minor-notice-bar__prefix {
  color: var(--color-text-muted);
  font-weight: 500;
}

.minor-notice-bar__sep {
  color: var(--color-text-muted);
}

.minor-notice-bar__close {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36rpx;
  height: 36rpx;
  margin: -4rpx -6rpx -4rpx 0;
  border-radius: 6rpx;
  box-sizing: border-box;
}

.minor-notice-bar__close--active {
  background: var(--color-mint-dim);
  opacity: 0.85;
}

.minor-notice-bar__close-icon {
  position: relative;
  width: 20rpx;
  height: 20rpx;
}

.minor-notice-bar__close-line {
  position: absolute;
  left: 50%;
  top: 50%;
  width: 20rpx;
  height: 2rpx;
  margin-left: -10rpx;
  margin-top: -1rpx;
  border-radius: 1rpx;
  background: var(--color-text-muted);
}

.minor-notice-bar__close-line--a {
  transform: rotate(45deg);
}

.minor-notice-bar__close-line--b {
  transform: rotate(-45deg);
}
