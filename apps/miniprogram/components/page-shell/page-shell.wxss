/* Skyline：宿主须占满 page，高度由 page-layout.js 注入 --page-window-h */
:host {
  display: flex;
  flex-direction: column;
  width: 100%;
  height: 100%;
  min-height: 0;
  flex: 1;
  box-sizing: border-box;
}

.page-shell__body {
  flex: 1;
  min-height: 0;
  height: var(--page-body-h, 0);
  display: flex;
  flex-direction: column;
  position: relative;
  width: 100%;
  box-sizing: border-box;
}
