<view class="product-card product-card--embed" bindtap="onTap">
  <view class="cover-wrap">
    <view class="cover-wrap__slot">
      <cover-media
        src="{{product.coverDisplay || product.cover}}"
        media-key="{{product.coverKey}}"
        color="{{product.coverColor}}"
        lazy-load="{{false}}"
      />
    </view>
    <text
      wx:if="{{product.tag}}"
      class="cover-tag {{product.tagClass}}"
    >{{product.tag}}</text>
    <view class="cover-foot">
      <price-badge value="{{product.priceDisplay}}" size="sm" thin />
      <text class="cover-sold">已售{{product.sold}}</text>
    </view>
  </view>
  <view class="info">
    <text class="title">{{product.title}}</text>
    <text class="desc">{{product.desc}}</text>
  </view>
</view>
