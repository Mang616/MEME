.select-sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 1200;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: flex-end;
  justify-content: center;
}

.select-sheet {
  width: 100%;
  max-height: 68vh;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  padding: 24rpx 24rpx calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.select-sheet__head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 56rpx;
  margin-bottom: 16rpx;
}

.select-sheet__side {
  width: 56rpx;
  height: 56rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.select-sheet__title {
  flex: 1;
  min-width: 0;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  text-align: center;
  line-height: 1.2;
}

.select-sheet__close {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  height: 56rpx;
  font-size: 40rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.select-sheet__list {
  max-height: calc(68vh - 120rpx);
}

.select-sheet-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 88rpx;
  padding: 20rpx;
  margin-bottom: 12rpx;
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-md);
  background: var(--color-bg-elevated);
  box-sizing: border-box;
}

.select-sheet-item.is-active {
  border-color: var(--color-mint);
  background: var(--color-mint-strong-dim);
}

.select-sheet-item.is-disabled {
  opacity: 0.55;
}

.select-sheet-item__main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  justify-content: center;
  gap: 6rpx;
}

.select-sheet-item__label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.35;
}

.select-sheet-item__hint {
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.4;
}

.select-sheet-item__extra {
  flex-shrink: 0;
  min-width: 88rpx;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-price);
  text-align: center;
  line-height: 1.2;
}

.select-sheet-item__extra.is-muted {
  font-weight: 500;
  color: var(--color-text-muted);
}
