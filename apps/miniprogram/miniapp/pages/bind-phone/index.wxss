@import '../../styles/theme/phone-form.wxss';

.bind-scroll {
  flex: 1;
  min-height: 0;
}

.bind-page {
  padding-top: 16rpx;
  padding-bottom: 24rpx;
  box-sizing: border-box;
}

.bind-page__hint {
  display: block;
  font-size: 26rpx;
  color: var(--color-text-muted);
  line-height: 1.5;
}

.bind-page__current {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--color-price);
}

.bind-page__form {
  margin-top: 32rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.bind-footer__submit {
  flex: 1;
  width: 100%;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  text-align: center;
  border-radius: var(--radius-pill);
  box-sizing: border-box;
}

.bind-footer__submit.is-loading {
  opacity: 0.75;
}

.bind-footer__submit:active {
  opacity: 0.88;
}
