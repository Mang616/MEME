<page-shell
  title="意见反馈"
  back="{{true}}"
  theme="{{theme}}"
  nav-color="{{navColor}}"
  nav-bg="{{navBg}}"
>
  <scroll-view class="page-scroll" scroll-y show-scrollbar="{{false}}">
    <view class="feedback-page page-tab-scroll-body">
      <block wx:if="{{!submitted}}">
        <view class="feedback-hero card">
          <view class="feedback-hero__stripe" />
          <view class="feedback-hero__inner">
            <text class="feedback-hero__title">告诉我们您的想法</text>
            <text class="feedback-hero__desc">您的建议将帮助我们改进产品体验。一般会在 1–3 个工作日内处理。</text>
          </view>
        </view>

        <view class="feedback-block card">
          <text class="feedback-block__label">反馈类型</text>
          <view class="feedback-types">
            <view
              wx:for="{{types}}"
              wx:key="id"
              class="feedback-type {{typeId === item.id ? 'feedback-type--active' : ''}}"
              data-id="{{item.id}}"
              bindtap="onTypeTap"
            >
              <text class="feedback-type__text">{{item.label}}</text>
            </view>
          </view>
        </view>

        <view class="feedback-block card">
          <view class="feedback-block__row">
            <text class="feedback-block__label">问题描述</text>
            <text class="feedback-block__count">{{contentLength}}/{{contentMax}}</text>
          </view>
          <textarea
            class="feedback-textarea"
            value="{{content}}"
            maxlength="{{contentMax}}"
            placeholder="请描述您遇到的问题或建议，至少 10 字"
            placeholder-class="feedback-textarea__placeholder"
            show-confirm-bar="{{false}}"
            bindinput="onContentInput"
          />
        </view>

        <view class="feedback-block card">
          <text class="feedback-block__label">联系方式（选填）</text>
          <input
            class="feedback-input"
            type="text"
            maxlength="50"
            value="{{contact}}"
            placeholder="手机号 / 微信号，便于我们回复您"
            placeholder-class="feedback-input__placeholder"
            bindinput="onContactInput"
          />
        </view>

        <view class="feedback-aside">
          <text class="feedback-aside__icon">ⓘ</text>
          <text class="feedback-aside__text">紧急订单问题可优先联系</text>
          <text class="feedback-aside__link" bindtap="onServiceTap">在线客服</text>
        </view>

        <button
          class="feedback-submit btn-primary"
          loading="{{submitting}}"
          disabled="{{submitting}}"
          bindtap="onSubmit"
        >
          提交反馈
        </button>
      </block>

      <view wx:else class="feedback-done card">
        <view class="feedback-done__icon">✓</view>
        <text class="feedback-done__title">已收到您的反馈</text>
        <text class="feedback-done__desc">我们会尽快处理。如需补充说明，可再次提交或联系在线客服。</text>
        <button class="feedback-done__btn btn-outline" bindtap="onSubmitAgain">继续反馈</button>
        <button class="feedback-done__btn btn-primary" bindtap="onServiceTap">联系客服</button>
      </view>
    </view>
  </scroll-view>
</page-shell>
