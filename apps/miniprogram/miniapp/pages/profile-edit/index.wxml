<page-shell
  title="个人资料"
  back="{{true}}"
  subpage="{{true}}"
  theme="{{theme}}"
  nav-color="{{navColor}}"
  nav-bg="{{navBg}}"
>
  <scroll-view class="page-scroll" scroll-y show-scrollbar="{{false}}">
    <view class="profile-edit page-pad-x page-tab-scroll-body">
      <view class="profile-edit__hero">
        <view class="profile-edit__avatar-ring">
          <image
            class="profile-edit__avatar"
            src="{{avatarSrc}}"
            mode="aspectFill"
          />
        </view>
        <text class="profile-edit__hero-hint">选择性别将同步更新默认头像</text>
      </view>

      <view class="profile-edit__card card">
        <view class="profile-edit__row profile-edit__row--input">
          <text class="profile-edit__label">昵称</text>
          <input
            class="profile-edit__input"
            value="{{nickname}}"
            maxlength="{{nicknameMax}}"
            placeholder="请输入昵称"
            placeholder-class="profile-edit__placeholder"
            bindinput="onNicknameInput"
            bindconfirm="onSaveNickname"
          />
        </view>

        <view class="profile-edit__row profile-edit__row--tap" bindtap="onGenderRowTap">
          <text class="profile-edit__label">性别</text>
          <view class="profile-edit__value-wrap">
            <text class="profile-edit__value">{{genderLabel}}</text>
            <text class="profile-edit__arrow">›</text>
          </view>
        </view>

        <view class="profile-edit__row profile-edit__row--tap profile-edit__row--last" bindtap="onBindPhoneTap">
          <text class="profile-edit__label">手机号</text>
          <view class="profile-edit__value-wrap">
            <text class="profile-edit__value">{{hasPhone ? phoneMasked : '未绑定'}}</text>
            <text class="profile-edit__arrow">›</text>
          </view>
        </view>
      </view>

      <view class="page-bottom-spacer" />
    </view>
  </scroll-view>

  <view class="page-footer-bar page-footer-bar--fixed profile-edit-footer">
    <view class="page-footer-bar__inner">
      <view
        class="profile-edit-footer__submit btn-primary {{saving ? 'is-loading' : ''}}"
        bindtap="onSaveNickname"
      >
        {{saving ? '保存中…' : '保存资料'}}
      </view>
    </view>
  </view>

  <view
    wx:if="{{genderSheetVisible}}"
    class="profile-edit-sheet-mask"
    bindtap="onCloseGenderSheet"
  >
    <view class="profile-edit-sheet" catchtap="preventClose">
      <view class="profile-edit-sheet__head">
        <text class="profile-edit-sheet__title">选择性别</text>
        <view
          class="profile-edit-sheet__close"
          hover-class="profile-edit-sheet__close--active"
          bindtap="onCloseGenderSheet"
        >
          <view class="profile-edit-sheet__close-line profile-edit-sheet__close-line--a" />
          <view class="profile-edit-sheet__close-line profile-edit-sheet__close-line--b" />
        </view>
      </view>
      <view class="profile-edit-sheet__list">
        <view
          wx:for="{{genderOptions}}"
          wx:key="id"
          class="profile-edit-sheet__option {{avatarGender === item.id ? 'is-selected' : ''}}"
          data-gender="{{item.id}}"
          bindtap="onGenderPick"
        >
          <text class="profile-edit-sheet__option-label">{{item.label}}</text>
          <text
            wx:if="{{avatarGender === item.id}}"
            class="profile-edit-sheet__check"
          >✓</text>
        </view>
      </view>
    </view>
  </view>
</page-shell>
