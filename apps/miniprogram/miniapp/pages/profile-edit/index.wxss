.profile-edit {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
  padding-top: 8rpx;
  padding-bottom: 32rpx;
  box-sizing: border-box;
}

/* —— 顶部头像（无卡片底） —— */
.profile-edit__hero {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx 0 8rpx;
  box-sizing: border-box;
}

.profile-edit__avatar-ring {
  padding: 6rpx;
  border-radius: 50%;
  background: linear-gradient(
    145deg,
    var(--color-mint) 0%,
    rgba(158, 212, 130, 0.35) 100%
  );
  box-sizing: border-box;
}

.profile-edit__avatar {
  width: 200rpx;
  height: 200rpx;
  border-radius: 50%;
  display: block;
  background: var(--color-bg-elevated);
  border: 4rpx solid var(--color-bg);
  box-sizing: border-box;
}

.profile-edit__hero-hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.45;
  text-align: center;
}

/* —— 表单卡片 —— */
.profile-edit__card {
  padding: 0;
  overflow: hidden;
}

.profile-edit__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 24rpx;
  min-height: 100rpx;
  padding: 0 28rpx;
  border-bottom: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.profile-edit__row--last {
  border-bottom: none;
}

.profile-edit__row--input {
  padding-top: 8rpx;
  padding-bottom: 8rpx;
}

.profile-edit__row--tap:active {
  background: var(--color-bg-elevated);
}

.profile-edit__label {
  flex-shrink: 0;
  font-size: 28rpx;
  color: var(--color-text-muted);
}

.profile-edit__input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  padding: 0 4rpx;
  font-size: 28rpx;
  color: var(--color-text);
  text-align: right;
  background: transparent;
  box-sizing: border-box;
}

.profile-edit__placeholder {
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.profile-edit__value-wrap {
  flex: 1;
  min-width: 0;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 8rpx;
}

.profile-edit__value {
  font-size: 28rpx;
  color: var(--color-text);
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-edit__arrow {
  flex-shrink: 0;
  font-size: 32rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.profile-edit-footer__submit {
  flex: 1;
  width: 100%;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1;
  text-align: center;
  border-radius: var(--radius-pill);
  box-sizing: border-box;
}

.profile-edit-footer__submit.is-loading {
  opacity: 0.75;
}

.profile-edit-footer__submit:active {
  opacity: 0.88;
}

/* —— 性别底部弹窗 —— */
.profile-edit-sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 200;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
}

.profile-edit-sheet {
  width: 100%;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  background: var(--color-card);
  border-top: 1rpx solid var(--color-border);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.profile-edit-sheet__head {
  position: relative;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 96rpx;
  padding: 0 88rpx;
  border-bottom: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.profile-edit-sheet__title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.3;
}

.profile-edit-sheet__close {
  position: absolute;
  right: 20rpx;
  top: 50%;
  transform: translateY(-50%);
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  box-sizing: border-box;
}

.profile-edit-sheet__close--active {
  background: var(--color-bg-elevated);
}

.profile-edit-sheet__close-line {
  position: absolute;
  width: 28rpx;
  height: 3rpx;
  border-radius: 2rpx;
  background: var(--color-text-muted);
}

.profile-edit-sheet__close-line--a {
  transform: rotate(45deg);
}

.profile-edit-sheet__close-line--b {
  transform: rotate(-45deg);
}

.profile-edit-sheet__list {
  padding: 8rpx 0;
}

.profile-edit-sheet__option {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  min-height: 96rpx;
  padding: 0 32rpx;
  box-sizing: border-box;
}

.profile-edit-sheet__option:active {
  background: var(--color-bg-elevated);
}

.profile-edit-sheet__option.is-selected {
  background: var(--color-mint-strong-dim);
}

.profile-edit-sheet__option-label {
  flex: 1;
  min-width: 0;
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 1.35;
}

.profile-edit-sheet__option.is-selected .profile-edit-sheet__option-label {
  font-weight: 600;
  color: var(--color-mint);
}

.profile-edit-sheet__check {
  flex-shrink: 0;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-mint);
  line-height: 1;
}
