.search-page {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  box-sizing: border-box;
}

.search-page__bar {
  flex-shrink: 0;
  padding-top: var(--page-header-block-gap);
  padding-bottom: var(--line-tabs-host-gap-below);
}

.search-page__field {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx 20rpx;
  border-radius: var(--radius-pill);
  background: var(--color-card);
  box-sizing: border-box;
}

.search-page__icon {
  font-size: 30rpx;
  color: var(--color-text-muted);
  line-height: 1;
  flex-shrink: 0;
}

.search-page__input {
  flex: 1;
  min-width: 0;
  height: 48rpx;
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 48rpx;
}

.search-page__placeholder {
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.search-page__clear {
  flex-shrink: 0;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  font-size: 36rpx;
  color: var(--color-text-muted);
}

.search-page__hint {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

/* 自定义组件宿主：占满 subpage 剩余高度，列表才能滚到底且留出 TabBar 间距 */
.search-page__list {
  flex: 1;
  min-height: 0;
  height: 0;
  width: 100%;
  display: flex;
  flex-direction: column;
}
