.account-scroll {
  flex: 1;
  min-height: 0;
}

.account-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 16rpx;
  box-sizing: border-box;
}

.account-balance {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 36rpx 28rpx 28rpx;
  box-sizing: border-box;
}

.account-balance__label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.account-balance__value {
  font-family: var(--font-display);
  font-size: 56rpx;
  font-weight: 700;
  color: var(--color-price);
  line-height: 1.1;
}

.account-balance__sub {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

.account-balance__action {
  width: 100%;
  height: 72rpx;
  margin-top: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-pill);
  box-sizing: border-box;
}

.account-section {
  padding: 24rpx;
  box-sizing: border-box;
}

.account-section__title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.account-ledger-item {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.account-ledger-item:last-child {
  border-bottom: none;
  padding-bottom: 0;
}

.account-ledger-item__main {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.account-ledger-item__type {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.3;
}

.account-ledger-item__remark {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.account-ledger-item__time {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.account-ledger-item__side {
  flex-shrink: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-end;
  gap: 6rpx;
}

.account-ledger-item__delta {
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.2;
}

.account-ledger-item__delta.is-plus {
  color: var(--color-mint);
}

.account-ledger-item__delta.is-minus {
  color: var(--color-price);
}

.account-ledger-item__after {
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.account-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 48rpx 0 32rpx;
  text-align: center;
}

.account-empty__icon {
  font-size: 48rpx;
  line-height: 1;
}

.account-empty__text {
  font-size: 28rpx;
  color: var(--color-text);
}

.account-empty__hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
