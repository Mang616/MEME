.chat-room {
  flex: 1;
  min-height: 0;
  display: flex;
  flex-direction: column;
  position: relative;
}

.chat-room__bar {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 8rpx;
  padding: 12rpx 24rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
  border-bottom: 1rpx solid var(--color-border);
  background: var(--color-bg-elevated);
}

.chat-room__role {
  color: var(--color-price);
}

.chat-room__dot {
  opacity: 0.5;
}

.chat-room__order-hint {
  margin-left: auto;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}

.chat-room__messages {
  flex: 1;
  min-height: 0;
  height: 0;
  width: 100%;
}

.chat-room__messages-inner {
  padding: 24rpx;
  padding-bottom: 16rpx;
  box-sizing: border-box;
}

.chat-room__row {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  margin-bottom: 24rpx;
  max-width: 88%;
}

.chat-room__row--self {
  align-self: flex-end;
  align-items: flex-end;
  margin-left: auto;
}

.chat-bubble {
  padding: 18rpx 22rpx;
  border-radius: var(--radius-md);
  max-width: 100%;
  box-sizing: border-box;
}

.chat-bubble--other {
  background: var(--color-card);
  border: 1rpx solid var(--color-border);
  border-bottom-left-radius: 6rpx;
}

.chat-bubble--self {
  background: var(--color-mint-dim);
  border: 1rpx solid var(--color-mint);
  border-bottom-right-radius: 6rpx;
}

.chat-bubble__text {
  font-size: 28rpx;
  color: var(--color-text);
  line-height: 1.45;
  word-break: break-all;
}

.chat-bubble--order {
  width: 480rpx;
  max-width: 100%;
  padding: 20rpx;
}

.chat-order-card__label {
  display: block;
  font-size: 22rpx;
  color: var(--color-text-muted);
  margin-bottom: 8rpx;
}

.chat-order-card__title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.35;
}

.chat-order-card__meta {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
  word-break: break-all;
}

.chat-order-card__pay {
  margin-top: 14rpx;
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.chat-order-card__pay-label {
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.chat-room__time {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: var(--color-text-muted);
}

.chat-room__composer {
  flex-shrink: 0;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 24rpx;
  padding-bottom: calc(20rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid var(--color-border);
  background: var(--color-bg-elevated);
  box-sizing: border-box;
}

/* 侧键：纯图标，无外圈 */
.chat-room__action {
  flex-shrink: 0;
  width: 56rpx;
  height: 84rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
}

.chat-room__action--active {
  opacity: 0.65;
}

.chat-room__action-icon {
  width: 52rpx;
  height: 52rpx;
  display: block;
}

.chat-room__input-wrap {
  flex: 1;
  min-width: 0;
  height: 84rpx;
  display: flex;
  align-items: center;
}

.chat-room__input {
  width: 100%;
  height: 84rpx;
  min-height: 84rpx;
  padding: 0 28rpx;
  font-size: 30rpx;
  line-height: 84rpx;
  color: var(--color-text);
  background: var(--color-bg);
  border: 1rpx solid var(--color-border);
  border-radius: var(--radius-pill);
  box-sizing: border-box;
}

.chat-room__input-placeholder {
  color: var(--color-text-muted);
  font-size: 28rpx;
}

.order-picker-mask {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  background: rgba(0, 0, 0, 0.55);
  display: flex;
  align-items: flex-end;
}

.order-picker-sheet {
  width: 100%;
  max-height: 70vh;
  border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  background: var(--color-card);
  border: 1rpx solid var(--color-border);
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.order-picker-sheet__head {
  position: relative;
  padding: 28rpx 24rpx 16rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.order-picker-sheet__title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: var(--color-text);
}

.order-picker-sheet__sub {
  display: block;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.order-picker-sheet__close {
  position: absolute;
  right: 24rpx;
  top: 28rpx;
  font-size: 36rpx;
  color: var(--color-text-muted);
  line-height: 1;
  padding: 8rpx;
}

.order-picker-sheet__list {
  flex: 1;
  min-height: 200rpx;
  max-height: 56vh;
  box-sizing: border-box;
}

.order-picker-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.order-picker-item:active {
  background: var(--color-bg-elevated);
}

.order-picker-item__main {
  flex: 1;
  min-width: 0;
}

.order-picker-item__title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.order-picker-item__sn {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
  word-break: break-all;
}

.order-picker-item__side {
  flex-shrink: 0;
  text-align: right;
}

.order-picker-item__status {
  display: block;
  font-size: 24rpx;
  color: var(--color-price);
}

.order-picker-item__player {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  color: var(--color-text-secondary);
}
