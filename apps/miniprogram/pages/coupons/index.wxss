.coupons-page {
  box-sizing: border-box;
}

.coupons-scroll {
  flex: 1;
  min-height: 0;
}

.coupons-list {
  box-sizing: border-box;
}

.coupons-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.coupon-card {
  display: flex;
  align-items: stretch;
  margin-bottom: 20rpx;
  overflow: hidden;
  box-sizing: border-box;
}

.coupon-card.is-inactive {
  opacity: 0.72;
}

.coupon-card__value {
  flex-shrink: 0;
  width: 168rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 28rpx 16rpx;
  box-sizing: border-box;
}

.coupon-card__value-text {
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-price);
  line-height: 1.1;
  text-align: center;
}

.coupon-card.is-inactive .coupon-card__value-text {
  color: var(--color-text-muted);
}

.coupon-card__divider {
  flex-shrink: 0;
  width: 0;
  border-left: 2rpx dashed var(--color-border);
  margin: 20rpx 0;
}

.coupon-card__body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
  padding: 24rpx 24rpx 24rpx 8rpx;
  box-sizing: border-box;
}

.coupon-card__head {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
}

.coupon-card__name {
  flex: 1;
  min-width: 0;
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  line-height: 1.35;
}

.coupon-card__status {
  flex-shrink: 0;
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.4;
}

.coupon-card__status.is-available {
  color: var(--color-mint-deep);
  font-weight: 600;
}

.coupon-card__hint {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.4;
}

.coupon-card__desc {
  font-size: 22rpx;
  color: var(--color-text-muted);
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.coupon-card__expires {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: var(--color-text-muted);
}

.coupons-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 80rpx 0 48rpx;
  text-align: center;
}

.coupons-empty__icon {
  font-size: 48rpx;
  line-height: 1;
}

.coupons-empty__text {
  font-size: 28rpx;
  color: var(--color-text);
}

.coupons-empty__hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
}
