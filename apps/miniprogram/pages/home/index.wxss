.home-top-notice {
  padding: 8rpx var(--page-pad-x) 0;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

.page-content {
  padding: 0 var(--page-pad-x);
  --service-tab-bleed-top: 48rpx;
}

.page-content .service-panel {
  margin-top: 0;
}

.home-banner-wrap {
  width: 100%;
}

.home-banner {
  width: 100%;
  height: 320rpx;
  margin-bottom: 8rpx;
}

.home-banner__item {
  height: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.banner-card {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.banner-card__media-stack {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.banner-card__media {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.banner-card__media--fallback {
  z-index: 0;
  background: var(--color-banner-fallback);
}

.banner-card__media--photo {
  z-index: 1;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.banner-card__media--photo.banner-card__media--visible {
  opacity: 1;
}
