.home-top-notice {
  padding: 8rpx var(--page-pad-x) 0;
  margin-bottom: 12rpx;
  box-sizing: border-box;
}

.page-content {
  padding: 0 var(--page-pad-x);
  --service-tab-bleed-top: 48rpx;
}

.page-content .service-panel {
  margin-top: 0;
}

.home-banner {
  width: 100%;
  height: 320rpx;
  margin-bottom: 8rpx;
}

.home-banner__item {
  height: 100%;
  padding: 0 24rpx;
  box-sizing: border-box;
}

.banner-card {
  position: relative;
  width: 100%;
  height: 100%;
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1rpx solid var(--color-border);
  box-shadow: var(--shadow-card);
}

.banner-card__media-stack {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
}

.banner-card__media {
  position: absolute;
  left: 0;
  top: 0;
  width: 100%;
  height: 100%;
  display: block;
}

.banner-card__media--fallback {
  z-index: 0;
  background: var(--color-banner-fallback);
}

.banner-card__media--photo {
  z-index: 1;
  opacity: 0;
  transition: opacity 0.25s ease;
}

.banner-card__media--photo.banner-card__media--visible {
  opacity: 1;
}

.banner-card__shade {
  position: absolute;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 2;
  pointer-events: none;
}

.banner-card--photo .banner-card__shade {
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.06) 0%,
    rgba(0, 0, 0, 0.28) 55%,
    rgba(0, 0, 0, 0.5) 100%
  );
}

.banner-card:not(.banner-card--photo) .banner-card__shade {
  background: linear-gradient(
    180deg,
    transparent 0%,
    rgba(0, 0, 0, 0.22) 100%
  );
}

.banner-card__content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 3;
  padding: 36rpx 32rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
  justify-content: flex-end;
  gap: 10rpx;
}

.banner-card__title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--color-banner-title);
  letter-spacing: 0.04em;
  line-height: 1.25;
  text-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.35);
}

.banner-card__subtitle {
  font-size: 26rpx;
  color: var(--color-banner-subtitle);
  line-height: 1.35;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.3);
}
