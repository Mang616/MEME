.invite-scroll {
  flex: 1;
  min-height: 0;
}

.invite-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  padding-top: 16rpx;
  box-sizing: border-box;
}

.invite-loading {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 80rpx 0;
  font-size: 26rpx;
  color: var(--color-text-muted);
}

.invite-hero {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  padding: 28rpx;
  border: 1rpx solid var(--color-mint-strong-dim);
  background: linear-gradient(135deg, #1a2a18 0%, #243828 45%, #1a2218 100%);
  box-sizing: border-box;
}

.invite-hero__tag {
  align-self: flex-start;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-on-accent);
  background: var(--color-mint);
  padding: 4rpx 14rpx;
  border-radius: var(--radius-pill);
}

.invite-hero__title {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-banner-title);
  line-height: 1.35;
}

.invite-hero__subtitle {
  font-size: 24rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.invite-poster {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}

.invite-poster__title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.invite-poster__image {
  width: 100%;
  border-radius: var(--radius-md);
  display: block;
}

.invite-poster__placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 480rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
  border-radius: var(--radius-md);
  background: var(--color-bg-elevated);
}

.invite-poster__hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
  text-align: center;
}

.invite-qr {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16rpx;
  padding: 32rpx 28rpx 28rpx;
  box-sizing: border-box;
}

.invite-qr__frame {
  width: 360rpx;
  height: 360rpx;
  padding: 20rpx;
  border-radius: var(--radius-md);
  background: #ffffff;
  box-sizing: border-box;
}

.invite-qr__image {
  width: 100%;
  height: 100%;
  display: block;
}

.invite-qr__placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.invite-qr__hint {
  font-size: 24rpx;
  color: var(--color-text-muted);
  text-align: center;
}

.invite-code {
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}

.invite-code__label {
  display: block;
  margin-bottom: 12rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
}

.invite-code__row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.invite-code__value {
  flex: 1;
  min-width: 0;
  font-family: var(--font-display);
  font-size: 40rpx;
  font-weight: 700;
  letter-spacing: 4rpx;
  color: var(--color-text);
}

.invite-code__btn {
  flex-shrink: 0;
  height: 56rpx;
  padding: 0 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-mint-deep);
  border: 1rpx solid var(--color-mint);
  border-radius: var(--radius-pill);
  box-sizing: border-box;
}

.invite-code__btn:active {
  opacity: 0.88;
}

.invite-rules {
  padding: 24rpx 28rpx;
  box-sizing: border-box;
}

.invite-rules__title {
  display: block;
  margin-bottom: 16rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
}

.invite-rule-item {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  padding: 12rpx 0;
}

.invite-rule-item__index {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-mint-deep);
  background: var(--color-mint-strong-dim);
  border-radius: 50%;
  line-height: 36rpx;
  text-align: center;
}

.invite-rule-item__text {
  flex: 1;
  min-width: 0;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  line-height: 1.5;
}

.invite-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  padding-bottom: 16rpx;
}

.invite-actions__share {
  width: 100%;
  height: 88rpx;
  margin: 0;
  padding: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: var(--radius-pill);
  box-sizing: border-box;
}

.invite-actions__share::after {
  border: none;
}

.invite-actions__save {
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
}

.invite-actions__save:active {
  opacity: 0.88;
}

.invite-actions__save--primary {
  color: var(--color-mint-deep);
  font-weight: 600;
}

.invite-actions__save.is-disabled {
  opacity: 0.5;
  pointer-events: none;
}
