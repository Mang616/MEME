<page-shell
  title="订单详情"
  back="{{true}}"
  theme="{{theme}}"
  nav-color="{{navColor}}"
  nav-bg="{{navBg}}"
>
  <scroll-view class="page-scroll" scroll-y show-scrollbar="{{false}}">
    <view class="order-detail-page page-tab-scroll-body">
      <block wx:if="{{found}}">
        <order-card
          mode="detail"
          order="{{order}}"
          bind:event="onOrderCardEvent"
        />
      </block>
      <view wx:else class="card">
        <list-empty
          size="compact"
          text="订单不存在"
          hint="请返回订单列表重试"
        />
      </view>
    </view>
  </scroll-view>
</page-shell>
