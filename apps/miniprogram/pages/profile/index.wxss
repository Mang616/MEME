@import '../../styles/level-icon-glow.wxss';

.profile-page {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
  box-sizing: border-box;
}

/* —— 顶部：用户 + 资产（无卡片底；左右与 .profile-section 内文 28rpx 对齐） —— */
.profile-head {
  display: flex;
  flex-direction: column;
  gap: 0;
  padding: 8rpx 28rpx 4rpx;
  box-sizing: border-box;
}

.profile-head__user {
  display: flex;
  align-items: center;
  gap: 24rpx;
  padding: 16rpx 0 20rpx;
  box-sizing: border-box;
}

.profile-head__user:active {
  opacity: 0.88;
}

.profile-head__avatar-box {
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
}

.profile-head__avatar-img {
  width: 100%;
  height: 100%;
  border-radius: 50%;
  display: block;
  background: var(--color-bg-elevated);
  border: 2rpx solid var(--color-border);
  box-sizing: border-box;
}

.profile-head__info {
  flex: 1;
  min-width: 0;
}

.profile-head__name-row {
  display: flex;
  align-items: center;
  flex-wrap: wrap;
  gap: 12rpx;
}

.profile-head__name {
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text);
  max-width: 100%;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.profile-vip {
  display: flex;
  align-items: center;
  gap: 6rpx;
  padding: 4rpx 14rpx 4rpx 8rpx;
  border-radius: var(--radius-pill);
  flex-shrink: 0;
  box-sizing: border-box;
}

.profile-vip:active {
  opacity: 0.82;
}

.profile-vip__icon-wrap {
  flex-shrink: 0;
  width: 36rpx;
  height: 36rpx;
}

.profile-vip__icon {
  width: 36rpx;
  height: 36rpx;
}

.profile-vip__label {
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.2;
  white-space: nowrap;
}

.profile-head__sub {
  display: block;
  margin-top: 10rpx;
  font-size: 24rpx;
  color: var(--color-text-muted);
  line-height: 1.35;
}

.profile-head__chevron {
  flex-shrink: 0;
  font-size: 40rpx;
  color: var(--color-text-muted);
  line-height: 1;
}

.profile-head__wallet {
  display: flex;
  align-items: stretch;
  padding: 8rpx 0 12rpx;
  box-sizing: border-box;
}

.profile-head__wallet-item {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 10rpx;
  padding: 4rpx 0;
  box-sizing: border-box;
}

.profile-head__wallet-item:active {
  opacity: 0.75;
}

.profile-head__wallet-divider {
  width: 1rpx;
  margin: 4rpx 20rpx;
  background: var(--color-border);
  flex-shrink: 0;
}

.profile-head__wallet-label {
  font-size: 22rpx;
  color: var(--color-text-muted);
  white-space: nowrap;
  line-height: 1.2;
}

.profile-head__wallet-value {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-price);
  line-height: 1.2;
}

/* —— 菜单分组 —— */
.profile-section {
  padding: 0;
  overflow: hidden;
}

.profile-section--menu .profile-menu__cell:first-child {
  border-top: none;
}

/* 帮助快捷入口：无卡片底，与页面背景一体 */
.profile-section--help {
  padding: 0;
  background: transparent;
  border: none;
  box-shadow: none;
}

.profile-help-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 4rpx 8rpx 12rpx;
  box-sizing: border-box;
}

.profile-help-grid__item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 8rpx 16rpx;
  box-sizing: border-box;
}

.profile-help-grid__item:active {
  opacity: 0.7;
}

.profile-help-grid__icon-img {
  width: 56rpx;
  height: 56rpx;
  display: block;
}

.profile-help-grid__name {
  font-size: 22rpx;
  color: var(--color-text-secondary);
  text-align: center;
  line-height: 1.3;
}

.profile-menu__cell {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 28rpx;
  border-top: 1rpx solid var(--color-border);
  box-sizing: border-box;
}

.profile-menu__cell:first-child {
  border-top: none;
}

.profile-menu__cell:active {
  background: var(--color-bg-elevated);
}

.profile-menu__label {
  font-size: 28rpx;
  color: var(--color-text);
}

.profile-menu__arrow {
  font-size: 32rpx;
  line-height: 1;
  color: var(--color-text-muted);
  flex-shrink: 0;
}
