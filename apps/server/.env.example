# API 监听端口（默认与 config/domains.json development.apiPort 一致）
PORT=3000

# MySQL（生产务必配置）。留空则回退 JSON 文件（仅本地开发）
DATABASE_URL=mysql://meme:meme@127.0.0.1:3306/meme

# 公开 URL（默认读取 config/domains.json，可在此覆盖）
# PUBLIC_SITE_URL=https://memepw.top
# PUBLIC_API_URL=https://api.memepw.top
# PUBLIC_ADMIN_URL=https://admin.memepw.top

# CORS 允许来源（逗号分隔，不设则用 domains.json + 本地开发端口）
# CORS_ORIGINS=https://memepw.top,https://admin.memepw.top

# 运营后台登录（生产环境务必修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Token 签名密钥（生产环境务必使用长随机串）
AUTH_SECRET=change-me-to-a-long-random-string

# 腾讯云 COS 图片存储（勿提交真实密钥到 Git）
# 在腾讯云控制台创建子账号密钥，并创建存储桶（格式通常为 桶名-APPID）
COS_SECRET_ID=你的SecretId
COS_SECRET_KEY=你的SecretKey
COS_APP_ID=1322855353
COS_BUCKET=你的桶名-1322855353
COS_REGION=ap-guangzhou
# false=公有读私有写（直链访问）；true=完全私有（签名 URL）
COS_PRIVATE=false
# 签名链接有效期（秒），默认 7200
# COS_SIGN_EXPIRES_SEC=7200
# 可选：自定义 CDN / 桶访问域名，不设则用 https://{COS_BUCKET}.cos.{COS_REGION}.myqcloud.com
# COS_PUBLIC_BASE=https://img.memepw.top
