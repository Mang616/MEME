# API 监听端口
PORT=3000

# MySQL（自建服务器）。配置后 API 使用 MySQL；留空则回退 JSON 文件（仅本地开发）
# 格式：mysql://用户:密码@主机:端口/数据库名
DATABASE_URL=mysql://meme:meme@127.0.0.1:3306/meme

# 运营后台登录（生产环境务必修改）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production

# Token 签名密钥（生产环境务必使用长随机串）
AUTH_SECRET=change-me-to-a-long-random-string
