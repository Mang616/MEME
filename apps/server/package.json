{
  "name": "@meme/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "npm run build --prefix ../../packages/types && npm run build --prefix ../../packages/admin-rbac && tsc -p tsconfig.json",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:seed": "tsx src/scripts/seed.ts",
    "db:migrate-handlers": "tsx src/scripts/migrate-handlers.ts",
    "smoke:admin-api": "tsx src/scripts/smoke-admin-api.ts",
    "upload:vip-icons": "tsx src/scripts/upload-vip-icons.ts"
  },
  "dependencies": {
    "@meme/admin-rbac": "*",
    "@meme/types": "*",
    "@meme/user-profile": "*",
    "@meme/vip-activity-defaults": "*",
    "@meme/invite-activity-defaults": "*",
    "@meme/register-activity-defaults": "*",
    "cors": "^2.8.5",
    "cos-nodejs-sdk-v5": "^2.15.4",
    "dotenv": "^16.5.0",
    "drizzle-orm": "^0.44.2",
    "express": "^5.1.0",
    "multer": "^2.2.0",
    "mysql2": "^3.14.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "zod": "^3.25.67"
  },
  "devDependencies": {
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.15.30",
    "@types/qrcode": "^1.5.6",
    "drizzle-kit": "^0.31.1",
    "tsx": "^4.20.3",
    "typescript": "^5.7.0"
  }
}
